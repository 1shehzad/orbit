# ── Slack ──────────────────────────────────────────────────
# See README.md for step-by-step Slack app setup instructions
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_USER_TOKEN=xoxp-your-user-token

# ── Linear ────────────────────────────────────────────────
LINEAR_API_KEY=lin_api_your-key
LINEAR_TEAM_ID=your-team-key-or-uuid

# ── AI Provider ──────────────────────────────────────────
# "claude" (default) or "codex"
AI_PROVIDER=claude
# Optional — uses CLI login by default (claude login / codex login)
ANTHROPIC_API_KEY=

# ── Project ───────────────────────────────────────────────
# PROJECT_FOLDER is optional — the bot auto-detects from message text,
# channel name, or WORKSPACE_ROOTS. Only set if you want a specific default.
# PROJECT_FOLDER=/path/to/your/project
BASE_BRANCH=staging

# ── Server ────────────────────────────────────────────────
PORT=3000

# ── Clarification ─────────────────────────────────────────
CLARIFY_TIMEOUT_MINUTES=10
MAX_CLARIFY_ROUNDS=3

# ── Persistence & QA ─────────────────────────────────────
ORBIT_DATA_DIR=.orbit-data
MAX_QA_RETRIES=3

# ── Access Control ────────────────────────────────────────
ALLOWED_USER_IDS=
# Owner Mode — bot monitors mentions of this Slack user ID
OWNER_USER_ID=

# ── Context ───────────────────────────────────────────────
CONTEXT_FOLDER=~/.orbit-context

# ── Standup ───────────────────────────────────────────────
STANDUP_CHANNEL_ID=
STANDUP_TIME=09:00

# ── Activity Monitoring ──────────────────────────────────
WORKSPACE_ROOTS=/path/to/workspace1,/path/to/workspace2
MONITOR_INTERVAL_MINUTES=5
SCREENSHOTS_ENABLED=true
SCREENSHOT_RETENTION_DAYS=7
ACTIVITY_CONTEXT_DAYS=7

# ── Away Mode ─────────────────────────────────────────────
AWAY_MODE_ENABLED=true
PRESENCE_POLL_SECONDS=60
