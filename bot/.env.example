# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token

# Linear
LINEAR_API_KEY=lin_api_your-key
LINEAR_TEAM_ID=your-team-key-or-uuid

# Claude / Anthropic (optional — uses CLI login by default)
ANTHROPIC_API_KEY=

# Project
PROJECT_FOLDER=/path/to/your/project
BASE_BRANCH=staging

# Server
PORT=3000

# Clarification
CLARIFY_TIMEOUT_MINUTES=10
MAX_CLARIFY_ROUNDS=3

# Persistence & QA
ORBIT_DATA_DIR=.orbit-data
MAX_QA_RETRIES=3

# Access Control
ALLOWED_USER_IDS=

# Owner Mode — bot monitors mentions of this Slack user ID and responds on their behalf
OWNER_USER_ID=
# Folder with .md files about you (role.md, daily.md, platform.md, etc.)
CONTEXT_FOLDER=~/.orbit-context
