{
  "display_information": {
    "name": "Orbit",
    "description": "Autonomous dev agent — analyzes problems, creates tickets, writes code, ships PRs",
    "background_color": "#1a1a2e"
  },
  "features": {
    "bot_user": {
      "display_name": "Orbit",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/orbit",
        "description": "Orbit dev agent commands",
        "usage_hint": "[status|tickets|work|help|prep|catchup|repos|reviews|standup]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "user": [
        "chat:write",
        "files:write",
        "users:read",
        "im:read",
        "im:history",
        "users.profile:read",
        "users.profile:write"
      ],
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:read",
        "chat:write",
        "commands",
        "files:write",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "users:read",
        "users:read.email"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
